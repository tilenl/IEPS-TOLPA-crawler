# ---------------------------------------
# Visualization DB profiles
# ---------------------------------------
# MOCK profile (usually local Docker on host port 5433)
MOCK_VIZ_DB_HOST=127.0.0.1
MOCK_VIZ_DB_PORT=5433
MOCK_VIZ_DB_USER=user
MOCK_VIZ_DB_PASSWORD=SecretPassword
MOCK_VIZ_DB_NAME=crawldb

# REAL profile (crawler database)
REAL_VIZ_DB_HOST=127.0.0.1
REAL_VIZ_DB_PORT=5432
REAL_VIZ_DB_USER=user
REAL_VIZ_DB_PASSWORD=SecretPassword
REAL_VIZ_DB_NAME=crawldb

# Fallback/default DB config (used by seed unless overridden)
VIZ_DB_HOST=127.0.0.1
VIZ_DB_PORT=5433
VIZ_DB_USER=user
VIZ_DB_PASSWORD=SecretPassword
VIZ_DB_NAME=crawldb

# API port
VIZ_PORT=3001

# ---------------------------------------
# Seed tuning (optional)
# ---------------------------------------
VIZ_SEED=42
VIZ_DOMAINS=example.com,foo.si,bar.gov.si
VIZ_HTML_PER_DOMAIN=80
VIZ_DUP_PER_DOMAIN=15
VIZ_FRONTIER_PER_DOMAIN=10
VIZ_ERROR_PER_DOMAIN=5
VIZ_BINARY_PER_DOMAIN=5
VIZ_CROSS_DOMAIN_LINKS=60
VIZ_INTRA_LINKS_PER_PAGE=3
